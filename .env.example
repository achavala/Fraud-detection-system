# Application
APP_NAME=fraud-detection-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass@localhost:5432/fraud_db
DATABASE_URL_SYNC=postgresql://fraud_user:fraud_pass@localhost:5432/fraud_db
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=fraud_pass
POSTGRES_DB=fraud_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_FRAUD_CASES=fraud_case_memory
QDRANT_COLLECTION_MERCHANT_PATTERNS=merchant_attack_patterns
QDRANT_COLLECTION_INVESTIGATOR_NOTES=investigator_notes

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI (embeddings)
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Anthropic (agent reasoning)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Slack notifications
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_FRAUD_OPS_CHANNEL=#fraud-ops-alerts
SLACK_MODEL_ALERTS_CHANNEL=#model-risk-alerts

# GitHub workflow
GITHUB_TOKEN=ghp_your-token
GITHUB_REPO=org/fraud-rules-config

# Scoring thresholds (defaults)
SCORE_THRESHOLD_DECLINE=0.85
SCORE_THRESHOLD_REVIEW=0.55
SCORE_THRESHOLD_STEPUP=0.35

# Feature service
FEATURE_CACHE_TTL_SECONDS=300
FEATURE_VERSION=v2.3.1

# Model defaults
CHAMPION_MODEL_VERSION=xgb-v4.2.0
SHADOW_MODEL_VERSIONS=lgb-v5.0.0-rc1

# Rate limiting
RATE_LIMIT_SCORING_RPS=5000
RATE_LIMIT_DASHBOARD_RPS=100
